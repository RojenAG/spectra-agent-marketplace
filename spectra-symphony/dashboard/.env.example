# Spectra Dashboard — copy to .env and fill in values
# -------------------------------------------------------
# Provider-agnostic token setup
# Set SPECTRA_PROVIDER + SPECTRA_API_TOKEN to use any backend.
# Legacy BASE44_SERVICE_TOKEN still works as a fallback.

# --- Provider selection ---
SPECTRA_PROVIDER=base44           # options: base44 | supabase | custom

# --- Token (provider-agnostic) ---
SPECTRA_API_TOKEN=your_token_here

# --- API base URL (auto-set for base44, override for other providers) ---
# SPECTRA_API_BASE=https://api.base44.com/api/apps/69f19298360c8dc869b3fd9b/entities

# --- WhatsApp send URL (auto-set for base44, override for other providers) ---
# SPECTRA_WA_SEND_URL=https://api.base44.com/api/apps/69f19298360c8dc869b3fd9b/whatsapp/send

# --- App config ---
BASE44_APP_ID=69f19298360c8dc869b3fd9b
SPRINT_ID=6a2d3bb0fa4d9a6245824bf2
WHATSAPP_RECIPIENT=+1234567890
PORT=8044

# --- Legacy fallback (still supported) ---
# BASE44_SERVICE_TOKEN=your_token_here
